# Supabase — Auth + Postgres
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 — bundle zip objects (S3 API)
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Or set R2_ACCOUNT_ID and omit R2_ENDPOINT
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
BUNDLE_STORAGE_BUCKET=bundle-archives

# CLI remote / E2E
CCB_API_URL=http://localhost:3000
CCB_ACCESS_TOKEN=
CCB_E2E_INTEGRATION=
