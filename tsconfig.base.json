{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@claude-code-bundles/core": ["packages/core/src/index.ts"],
      "@claude-code-bundles/core/*": ["packages/core/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "apps/web/.next"]
}
