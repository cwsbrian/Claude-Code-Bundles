# Supabase — Auth + Postgres only (bundle binaries are on R2)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Or use NEXT_PUBLIC_SUPABASE_ANON_KEY from newer Connect snippets
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only: Postgres writes bypass RLS as intended for API; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (S3-compatible) — server-only API token
# Docs: https://developers.cloudflare.com/r2/api/s3/api/
R2_ACCOUNT_ID=your_cloudflare_account_id
# Or set full URL: R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_api_token_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_api_token_secret

# Bucket name (create in R2 dashboard)
BUNDLE_STORAGE_BUCKET=bundle-archives
